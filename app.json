{
  "expo": {
    "name": "CineNative",
    "slug": "CineNative",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo1.png",
    "scheme": "cinenative",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salony.cinenative"
    },
    "android": {
      "package": "com.salony.cinenative",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo1.png",
        "backgroundColor": "#030014"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo1.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#030014"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "445a1922-36f4-4d39-92ab-a7389ebaa994"
      }
    }
  }
}
